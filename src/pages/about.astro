---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getConfig } from '../lib/config';
import fs from 'fs';
import path from 'path';

const config = getConfig();

const aboutConfigPath = path.resolve(process.cwd(), 'about', 'config.json');
let aboutConfig = config.about;

if (fs.existsSync(aboutConfigPath)) {
  try {
    const aboutConfigData = fs.readFileSync(aboutConfigPath, 'utf-8');
    aboutConfig = JSON.parse(aboutConfigData);
  } catch (error) {
    console.error('Error reading about config:', error);
  }
}
---

<BaseLayout title="关于">
  <a href="/" class="back-button">
    <span class="back-arrow"></span>
    返回首页
  </a>
  
  <section class="about">
    <div class="about-header">
      <div class="avatar-large">
        {config.avatar.useImage && config.avatar.imageUrl ? (
          <img src={config.avatar.imageUrl} alt={config.site.author} class="avatar-image-large" />
        ) : (
          <div class="avatar-placeholder-large">{config.avatar.text}</div>
        )}
      </div>
      <h1 class="about-title">{aboutConfig.title}</h1>
      <p class="about-subtitle">{aboutConfig.subtitle}</p>
    </div>

    <div class="about-content">
      <div class="about-section">
        <h2>博客介绍</h2>
        {aboutConfig.introduction.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <div class="about-section">
        <h2>技术栈</h2>
        <div class="tech-stack">
          {aboutConfig.techStack.map((tech) => (
            <div class="tech-item">
              <span class="tech-name">{tech.name}</span>
              <span class="tech-desc">{tech.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="about-section">
        <h2>联系方式</h2>
        <div class="contact-links">
          {config.social.github && (
            <a href={config.social.github} target="_blank" class="contact-link">
              <span class="contact-icon">GitHub</span>
              <span class="contact-text">{config.social.github.split('/').pop()}</span>
            </a>
          )}
          {config.social.email && (
            <a href={`mailto:${config.social.email}`} class="contact-link">
              <span class="contact-icon">Email</span>
              <span class="contact-text">联系我</span>
            </a>
          )}
        </div>
      </div>

      <div class="about-section">
        <h2>博客功能</h2>
        <ul class="feature-list">
          {aboutConfig.features.map((feature) => (
            <li>{feature}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    background: var(--card);
    border: 1px solid var(--border);
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px var(--shadow);
    text-decoration: none;
  }

  .back-button:hover {
    color: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateX(-4px);
  }

  .back-arrow {
    display: inline-block;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-right: 6px solid currentColor;
    transition: transform 0.3s ease;
  }

  .back-button:hover .back-arrow {
    transform: translateX(-3px);
  }

  .about {
    padding: 2rem 0;
  }

  .about-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .avatar-large {
    margin-bottom: 1.5rem;
  }

  .avatar-placeholder-large {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    font-size: 3rem;
    font-weight: 700;
    color: white;
    box-shadow: 0 8px 30px var(--shadow);
  }

  .avatar-image-large {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto;
    display: block;
    box-shadow: 0 8px 30px var(--shadow);
  }

  .about-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .about-subtitle {
    font-size: 1.125rem;
    color: var(--muted);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .about-section {
    background: var(--card);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px var(--shadow);
  }

  .about-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text);
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--border);
  }

  .about-section p {
    color: var(--text);
    opacity: 0.85;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-section p:last-child {
    margin-bottom: 0;
  }

  .tech-stack {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .tech-item {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tech-name {
    font-weight: 600;
    color: var(--accent);
  }

  .tech-desc {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--bg-secondary);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .contact-link:hover {
    background: var(--accent);
    color: white;
    transform: translateY(-2px);
  }

  .contact-icon {
    font-weight: 600;
  }

  .contact-text {
    font-size: 0.875rem;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .feature-list li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text);
    opacity: 0.85;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  @media (max-width: 640px) {
    .about-title {
      font-size: 2rem;
    }

    .about-section {
      padding: 1.5rem;
    }

    .tech-stack {
      grid-template-columns: 1fr;
    }

    .feature-list {
      grid-template-columns: 1fr;
    }

    .contact-links {
      flex-direction: column;
    }
  }
</style>
