---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getConfig } from '../lib/config';

const config = getConfig();
---

<BaseLayout title="友情链接">
  <a href="/" class="back-button">
    <span class="back-arrow"></span>
    返回首页
  </a>
  
  <section class="friends">
    <h1 class="page-title">友情链接</h1>
    
    <div class="friends-grid">
      {config.friends.map((friend) => (
        <a href={friend.url} target="_blank" class="friend-card">
          <div class="friend-avatar">
            <img src={friend.avatar} alt={friend.name} loading="lazy" />
          </div>
          <div class="friend-info">
            <h3 class="friend-name">{friend.name}</h3>
            <p class="friend-desc">{friend.description}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="apply-section">
      <h2>申请友链</h2>
      <p>欢迎交换友链！请确保您的网站符合以下要求：</p>
      <ul>
        <li>网站内容健康、积极向上</li>
        <li>网站能够正常访问</li>
        <li>优先考虑技术类博客</li>
      </ul>
      <p>请在评论区或通过邮件提供以下信息：</p>
      <ul>
        <li>网站名称</li>
        <li>网站地址</li>
        <li>网站描述</li>
        <li>头像链接（可选）</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    background: var(--card);
    border: 1px solid var(--border);
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px var(--shadow);
    text-decoration: none;
  }

  .back-button:hover {
    color: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateX(-4px);
  }

  .back-arrow {
    display: inline-block;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-right: 6px solid currentColor;
    transition: transform 0.3s ease;
  }

  .back-button:hover .back-arrow {
    transform: translateX(-3px);
  }

  .friends {
    padding: 2rem 0;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--text);
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .friend-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 2px 8px var(--shadow);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .friend-card:hover {
    box-shadow: 0 8px 24px var(--shadow);
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .friend-avatar {
    flex-shrink: 0;
  }

  .friend-avatar img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
  }

  .friend-info {
    flex: 1;
    min-width: 0;
  }

  .friend-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.25rem 0;
  }

  .friend-card:hover .friend-name {
    color: var(--accent);
  }

  .friend-desc {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .apply-section {
    background: var(--card);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px var(--shadow);
  }

  .apply-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .apply-section p {
    color: var(--text);
    opacity: 0.85;
    margin-bottom: 1rem;
  }

  .apply-section ul {
    color: var(--text);
    opacity: 0.85;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .apply-section li {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 640px) {
    .page-title {
      font-size: 1.5rem;
    }

    .friends-grid {
      grid-template-columns: 1fr;
    }

    .friend-card {
      padding: 1rem;
    }

    .apply-section {
      padding: 1.5rem;
    }
  }
</style>
