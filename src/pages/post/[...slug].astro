---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, description, tags, cover, category } = post.frontmatter;
---

<BaseLayout title={title} description={description}>
  <a href="/" class="back-button">
    <span class="back-arrow"></span>
    返回首页
  </a>
  
  <article class="post">
    {cover && (
      <div class="post-cover">
        <img src={cover} alt={title} loading="lazy" />
      </div>
    )}
    
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time class="post-date">{date}</time>
        <span class="reading-time">{post.readingTime} 分钟阅读</span>
        {category && (
          <a href={`/categories#${category}`} class="post-category">{category}</a>
        )}
      </div>
      {description && <p class="post-desc">{description}</p>}
      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    
    {post.toc && post.toc.length > 0 && (
      <nav class="toc">
        <h3>目录</h3>
        <ul>
          {post.toc.map((heading) => (
            <li class={`toc-level-${heading.level}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}
    
    <div class="post-content" set:html={post.html} />
  </article>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">&times;</button>
    <img class="lightbox-image" id="lightbox-image" src="" alt="" />
  </div>
</BaseLayout>

<style>
  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    background: var(--card);
    border: 1px solid var(--border);
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px var(--shadow);
    text-decoration: none;
  }

  .back-button:hover {
    color: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateX(-4px);
  }

  .back-arrow {
    display: inline-block;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-right: 6px solid currentColor;
    transition: transform 0.3s ease;
  }

  .back-button:hover .back-arrow {
    transform: translateX(-3px);
  }

  .post {
    background: var(--card);
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 4px 20px var(--shadow);
    overflow: hidden;
  }

  .post-cover {
    margin: -2.5rem -2.5rem 2rem -2.5rem;
    overflow: hidden;
    border-radius: 16px 16px 0 0;
  }

  .post-cover img {
    width: 100%;
    height: auto;
    max-height: 400px;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .post-cover img:hover {
    transform: scale(1.02);
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .post-header h1 {
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-date {
    display: inline-block;
    background: var(--bg-secondary);
    padding: 0.4rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .reading-time {
    display: inline-block;
    background: var(--bg-secondary);
    padding: 0.4rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .post-category {
    display: inline-block;
    background: var(--accent);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .post-category:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  .post-desc {
    color: var(--muted);
    font-size: 1.1rem;
    margin: 0 0 1rem 0;
    line-height: 1.7;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    display: inline-block;
    background: var(--accent);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .toc {
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
  }

  .toc h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--text);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    margin-bottom: 0.5rem;
  }

  .toc a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .toc a:hover {
    color: var(--accent);
  }

  .toc-level-2 {
    padding-left: 1rem;
  }

  .toc-level-3 {
    padding-left: 2rem;
  }

  .post-content {
    font-size: 1.0625rem;
  }

  .post-content h2 {
    margin-top: 2.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--border);
  }

  .post-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }

  .post-content p {
    margin-bottom: 1.25rem;
    color: var(--text);
    opacity: 0.85;
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 1.25rem;
  }

  .post-content li {
    margin-bottom: 0.5rem;
  }

  .post-content p img,
  .post-content img {
    max-width: calc(100% - 4rem);
    width: auto;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 8px 30px var(--shadow);
    margin: 2rem auto;
    display: block;
    cursor: zoom-in;
    transition: transform 0.3s ease;
    content-visibility: auto;
  }

  .post-content img:hover {
    transform: scale(1.02);
  }

  .post-content a img {
    cursor: pointer;
  }

  .post-content pre {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border: 2px solid #334155;
    border-radius: 12px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    line-height: 1.7;
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.2),
      0 2px 4px -2px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    position: relative;
  }

  .post-content pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #4361ee, #a78bfa, #f472b6);
    border-radius: 12px 12px 0 0;
  }

  .post-content pre code {
    background: transparent;
    padding: 0;
    font-size: inherit;
    color: #e2e8f0;
    font-family: 'Fira Code', 'JetBrains Mono', 'SF Mono', Consolas, Monaco, monospace;
  }

  .post-content code {
    background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.875em;
    font-family: 'Fira Code', 'JetBrains Mono', 'SF Mono', Consolas, Monaco, 'Andale Mono', monospace;
    color: #4338ca;
    border: 1px solid #a5b4fc;
    font-weight: 500;
  }

  .post-content pre code {
    color: #e2e8f0;
    border: none;
    font-weight: 400;
    background: transparent;
  }

  .lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .lightbox.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10000;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
    transform: rotate(90deg);
  }

  .lightbox-image {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .lightbox.active .lightbox-image {
    transform: scale(1);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .post {
      padding: 1.5rem;
      border-radius: 12px;
    }

    .post-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .toc {
      padding: 1rem;
    }

    .lightbox-close {
      top: 1rem;
      right: 1rem;
      width: 40px;
      height: 40px;
      font-size: 1.5rem;
    }

    .lightbox-image {
      max-width: 95%;
      max-height: 95%;
    }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image');
  const lightboxClose = document.getElementById('lightbox-close');
  const postContent = document.querySelector('.post-content');
  const postCover = document.querySelector('.post-cover');

  if (postCover) {
    const coverImg = postCover.querySelector('img');
    if (coverImg) {
      coverImg.addEventListener('click', () => {
        lightboxImage.src = coverImg.src;
        lightboxImage.alt = coverImg.alt;
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    }
  }

  if (postContent) {
    const images = postContent.querySelectorAll('img');
    
    images.forEach((img) => {
      img.addEventListener('click', () => {
        lightboxImage.src = img.src;
        lightboxImage.alt = img.alt;
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });
  }

  lightboxClose.addEventListener('click', closeLightbox);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('active')) {
      closeLightbox();
    }
  });

  function closeLightbox() {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  }
</script>